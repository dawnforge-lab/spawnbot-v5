FROM alpine:3.21

ARG TARGETPLATFORM

RUN apk add --no-cache ca-certificates tzdata

COPY $TARGETPLATFORM/spawnbot /usr/local/bin/spawnbot
COPY $TARGETPLATFORM/spawnbot-launcher /usr/local/bin/spawnbot-launcher
COPY $TARGETPLATFORM/spawnbot-launcher-tui /usr/local/bin/spawnbot-launcher-tui

ENTRYPOINT ["spawnbot-launcher"]
CMD ["-public", "-no-browser"]
